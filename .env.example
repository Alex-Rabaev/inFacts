# ---- API ----
NODE_ENV=development
API_PORT=3030
# CORS allowlist (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# ---- Database (PostgreSQL) ----
# Host port 5433 to avoid clashing with other local Postgres instances;
# docker-compose maps 5433 -> container 5432.
DATABASE_URL=postgresql://infacts:infacts@localhost:5433/infacts

# ---- Auth (set strong values in real envs) ----
ACCESS_TOKEN_SECRET=change-me-access
REFRESH_TOKEN_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600

# ---- Realtime ----
SOCKET_ORIGINS=http://localhost:5173

# ---- S3 / object storage ----
S3_REGION=us-east-1
S3_BUCKET=infacts-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ---- Docker compose ----
# Host port for the containerized web app (defaults to 5173).
#WEB_PORT=5173

# ---- Web (Vite, must be prefixed VITE_) ----
VITE_API_BASE_URL=http://localhost:3030
VITE_SOCKET_URL=http://localhost:3030
