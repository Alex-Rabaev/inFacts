{
  "name": "infacts",
  "version": "0.1.0",
  "private": true,
  "description": "inFacts — fact-sharing social network (TypeScript monorepo).",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "dev:api": "pnpm --filter @infacts/api run dev",
    "dev:web": "pnpm --filter @infacts/web run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.20.0"
  }
}
